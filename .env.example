# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hiresense

# Authentication
JWT_SECRET=your_super_secret_jwt_token
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# AI Intelligence (Gemini AI)
GEMINI_API_KEY=your_google_gemini_api_key_here

# Client URL (for CORS)
VITE_API_URL=https://hiresense-ai-v2.vercel.app/api
